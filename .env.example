# Telegram Bot Config
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id_here

# Database Config
# SQLite async format: sqlite+aiosqlite:///finance_bot.db
# PostgreSQL async format: postgresql+asyncpg://user:password@localhost:5432/db_name
DATABASE_URL=sqlite+aiosqlite:///finance_bot.db

# External APIs
OPENAI_API_KEY=

# Settings
LOG_LEVEL=INFO
